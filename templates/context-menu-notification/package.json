{
  "$schema": "./node_modules/@sigma-file-manager/api/manifest.schema.json",
  "id": "your-name.my-extension",
  "name": "My Extension",
  "version": "1.0.0",
  "publisher": {
    "name": "your-name",
    "url": "https://github.com/your-name"
  },
  "repository": "https://github.com/your-name/my-extension",
  "license": "MIT",
  "categories": [
    "Example"
  ],
  "extensionType": "api",
  "type": "module",
  "main": "dist/index.js",
  "permissions": [
    "contextMenu",
    "notifications",
    "clipboard"
  ],
  "activationEvents": [
    "onStartup"
  ],
  "contributes": {
    "contextMenu": [
      {
        "id": "my-extension.example-notification",
        "title": "Example Notification",
        "icon": "Bell",
        "group": "extensions",
        "order": 1
      },
      {
        "id": "my-extension.count-selected",
        "title": "Count Selected Items",
        "icon": "Hash",
        "group": "extensions",
        "order": 2,
        "when": {
          "selectionType": "multiple"
        }
      },
      {
        "id": "my-extension.copy-path",
        "title": "Copy Path",
        "icon": "Copy",
        "group": "extensions",
        "order": 3,
        "when": {
          "selectionType": "single"
        }
      }
    ]
  },
  "engines": {
    "sigmaFileManager": ">=2.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@sigma-file-manager/api": "^1.5.0",
    "typescript": "~5.8.0"
  }
}